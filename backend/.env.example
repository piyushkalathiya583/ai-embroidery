# App
APP_NAME="AI Embroidery Sketch Composer"
DEBUG=true
SECRET_KEY="change-me-to-a-long-random-string"
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Database (SQLite for dev; swap to Postgres in prod)
DATABASE_URL="sqlite:///./embroidery.db"

# Storage
UPLOAD_DIR="./storage/uploads"
THUMBNAIL_DIR="./storage/thumbnails"
MAX_UPLOAD_MB=15

# Providers
# VISION_PROVIDER: "openai" or "gemini" (free tier) — used by Modules 4 & 12
# IMAGE_PROVIDER:  "openai" or "pollinations" (free, keyless) — used by Module 11
VISION_PROVIDER="openai"
IMAGE_PROVIDER="openai"

# OpenAI / Image model
OPENAI_API_KEY="sk-..."
VISION_MODEL="gpt-4o"
IMAGE_MODEL="gpt-image-1"

# Free dev providers
GEMINI_API_KEY=""              # https://aistudio.google.com/apikey
GEMINI_MODEL="gemini-2.0-flash"
POLLINATIONS_MODEL="flux"
